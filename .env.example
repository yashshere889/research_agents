LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...
HF_TOKEN=hf_...
E2B_API_KEY=e2b_...
AGENT_MODEL=gemini-2.5-pro
REVIEWER_MODEL=gemini-2.5-flash
HF_LOAD_IN_4BIT=false
HF_TORCH_DTYPE=auto
HF_ATTN_IMPLEMENTATION=auto
